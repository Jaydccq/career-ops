{
  "manifest_version": 3,
  "name": "career-ops",
  "short_name": "career-ops",
  "version": "0.1.0",
  "description": "Local-first job posting evaluation. Bridges your browser to the career-ops pipeline running on your machine.",
  "action": {
    "default_title": "career-ops",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "http://127.0.0.1/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}

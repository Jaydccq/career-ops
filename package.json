{
  "name": "career-ops",
  "private": true,
  "version": "1.0.0",
  "description": "AI-powered job search pipeline built on Claude Code",
  "scripts": {
    "doctor": "node doctor.mjs",
    "verify": "node verify-pipeline.mjs",
    "normalize": "node normalize-statuses.mjs",
    "dedup": "node dedup-tracker.mjs",
    "merge": "node merge-tracker.mjs",
    "pdf": "node generate-pdf.mjs",
    "sync-check": "node cv-sync-check.mjs",
    "update:check": "node update-system.mjs check",
    "update": "node update-system.mjs apply",
    "rollback": "node update-system.mjs rollback",
    "liveness": "node check-liveness.mjs",
    "cover-letter": "node generate-cover-letter.mjs",
    "latex": "node generate-latex.mjs",
    "scan": "node scan.mjs",
    "gemini:eval": "node gemini-eval.mjs",
    "builtin-scan": "./apps/server/node_modules/.bin/tsx scripts/job-board-scan-bb-browser.ts --source builtin",
    "builtin-scan:legacy": "node scan.mjs --builtin-only",
    "newgrad-scan:login": "node scripts/newgrad-scan-login.mjs",
    "newgrad-scan": "./apps/server/node_modules/.bin/tsx scripts/newgrad-scan-autonomous.ts",
    "linkedin-scan": "./apps/server/node_modules/.bin/tsx scripts/linkedin-scan-bb-browser.ts",
    "indeed-scan": "./apps/server/node_modules/.bin/tsx scripts/job-board-scan-bb-browser.ts --source indeed",
    "auto:hourly-scan": "node scripts/hourly-job-scan.mjs",
    "auto:hourly-scan:dry": "CAREER_OPS_SCAN_DRY_RUN=1 node scripts/hourly-job-scan.mjs",
    "newgrad-rerun-history": "./apps/server/node_modules/.bin/tsx scripts/rerun-newgrad-history.ts",
    "pending:warm-cache": "node scripts/warm-legacy-pending-cache.mjs",
    "gmail:update": "node scripts/refresh-gmail-signals.mjs",
    "gmail:auth": "node scripts/gmail-oauth-refresh.mjs auth",
    "gmail:scan": "node scripts/gmail-oauth-refresh.mjs scan",
    "dashboard": "echo 'open http://127.0.0.1:47319/dashboard/'",
    "dashborad": "echo 'open http://127.0.0.1:47319/dashboard/'",
    "dashboard:build": "node web/build-dashboard.mjs",
    "ext:build": "pnpm --filter @career-ops/extension run build",
    "server": "node scripts/bridge-start.mjs",
    "server:dev": "pnpm --filter @career-ops/extension run build && pnpm run server",
    "ext:launcher": "node scripts/extension-launcher.mjs",
    "app:install": "node scripts/install-launch-agent.mjs",
    "app:uninstall": "node scripts/uninstall-launch-agent.mjs",
    "app:status": "node scripts/app-status.mjs",
    "app:logs": "node scripts/app-logs.mjs",
    "app:logs:err": "node scripts/app-logs.mjs --err",
    "app:restart": "launchctl kickstart -k gui/$(id -u)/io.hongxi.career-ops"
  },
  "keywords": [
    "ai",
    "job-search",
    "claude-code",
    "career",
    "automation"
  ],
  "author": "Santiago Fernández de Valderrama <hi@santifer.io> (https://santifer.io)",
  "homepage": "https://santifer.io",
  "repository": {
    "type": "git",
    "url": "https://github.com/santifer/career-ops"
  },
  "license": "MIT",
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "dotenv": "^16.4.5",
    "js-yaml": "^4.1.1",
    "playwright": "^1.58.1"
  }
}
